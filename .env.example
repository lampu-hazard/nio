# Docker Hub namespace used by docker-compose.yml image references.
# Example: lampuhazard or your Docker Hub username/organization.
DOCKERHUB_NAMESPACE=your-dockerhub-username

# Image tag to pull/run. Use "latest" for the most recent main build,
# or a Git commit SHA tag generated by GitHub Actions for rollback-safe deploys.
IMAGE_TAG=latest

# Discord AI Moderator Copilot Settings
DISCORD_AGENT_ENABLED=false
DISCORD_AGENT_PROVIDER=gemini
DISCORD_AGENT_MODEL=gemini-2.5-flash
DISCORD_AGENT_ALLOWED_USER_IDS=
GEMINI_API_KEY=
