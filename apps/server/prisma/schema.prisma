generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id
  username   String
  globalName String?
  avatar     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  auditLogs  AuditLog[]
  panels     Panel[]
}

model Guild {
  id              String            @id
  name            String
  icon            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  settings        GuildSettings?
  panels          Panel[]
  stickers        Sticker[]
  warnings        Warning[]
  takoIntegration TakoIntegration?
  takoDonations   TakoDonation[]
}

model GuildSettings {
  guildId                String   @id
  logChannelId           String?
  defaultStyle           String   @default("PREMIUM")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  stickerEnabled         Boolean  @default(false)
  slowmodeChannels       String[] @default([])
  slowmodeEnabled        Boolean  @default(false)
  slowmodeIntervalBusy   Int      @default(10)
  slowmodeIntervalQuiet  Int      @default(0)
  slowmodeIntervalNormal Int      @default(5)
  anomalyEnabled              Boolean  @default(false)
  phishingDetectionEnabled    Boolean  @default(true)
  contentAnomalyEnabled       Boolean  @default(true)
  userAnomalyEnabled          Boolean  @default(true)
  guildBaselineEnabled        Boolean  @default(true)
  anomalyEnforcementMode      String   @default("AUDIT_ONLY")

  // New Moderation Settings
  warnLimitEnabled       Boolean  @default(false)
  warnLimitThreshold     Int      @default(3)
  warnTimeoutDurationMin Int      @default(60)
  warnExpiryDays         Int      @default(30) // 0 = Never Expire

  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model Panel {
  id              String      @id @default(cuid())
  guildId         String
  createdById     String
  channelId       String?
  messageId       String?
  name            String
  title           String
  accentText      String?
  description     String?
  type            PanelType   @default(SELF_ROLE)
  mode            PanelMode   @default(BUTTONS)
  style           PanelStyle  @default(PREMIUM)
  color           String      @default("#5865F2")
  imageUrl        String?
  thumbnailUrl    String?
  maxRoles        Int         @default(0)
  requireRoleId   String?
  status          PanelStatus @default(DRAFT)
  lastPublishedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  auditLogs       AuditLog[]
  createdBy       User        @relation(fields: [createdById], references: [id])
  guild           Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roles           PanelRole[]
  logs            RoleLog[]
}

model PanelRole {
  id          String      @id @default(cuid())
  panelId     String
  roleId      String
  emoji       String?
  label       String
  description String?
  buttonStyle ButtonStyle @default(SECONDARY)
  position    Int
  panel       Panel       @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([panelId, roleId])
}

model RoleLog {
  id        String     @id @default(cuid())
  guildId   String
  userId    String
  roleId    String
  action    RoleAction
  panelId   String?
  createdAt DateTime   @default(now())
  panel     Panel?     @relation(fields: [panelId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  panelId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  panel     Panel?   @relation(fields: [panelId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Sticker {
  id        String   @id @default(cuid())
  guildId   String
  name      String
  url       String
  type      String
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, name])
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
}

enum PanelType {
  SELF_ROLE
  RULES
  ANNOUNCEMENT
}

enum PanelMode {
  BUTTONS
  MENU
}

enum PanelStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PanelStyle {
  PREMIUM
  MINIMAL
  COLORFUL
  NEON
}

enum ButtonStyle {
  PRIMARY
  SECONDARY
  SUCCESS
  DANGER
}

enum RoleAction {
  ADD
  REMOVE
}

model Warning {
  id          String    @id @default(cuid())
  guildId     String
  userId      String
  moderatorId String
  reason      String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([userId])
}

model BoosterRoleClaimToken {
  token     String   @id
  guildId   String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([guildId, userId])
}

model BoosterCustomRole {
  id             String    @id @default(cuid())
  guildId        String
  userId         String
  roleId         String    @unique
  name           String
  color          String
  primaryColor   String    @default("#ffffff")
  secondaryColor String?
  tertiaryColor  String?
  iconUrl        String?
  active         Boolean   @default(true)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([guildId, userId])
}

model TakoIntegration {
  guildId        String   @id
  enabled        Boolean  @default(false)
  creatorSlug    String?
  apiKey         String?
  webhookToken   String?
  rewardRoleId   String?
  minimumAmount  Int      @default(10000)
  paymentMethods String[] @default(["qris"])
  logChannelId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model TakoDonation {
  id             String    @id @default(cuid())
  guildId        String
  discordUserId  String
  transactionId  String?   @unique
  amount         Int
  paymentMethod  String
  senderName     String
  email          String
  message        String?
  status         String    @default("PENDING") // PENDING, PAID, ROLE_ASSIGNED, FAILED, IGNORED
  failureReason  String?
  roleAssignedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  guild          Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([discordUserId])
  @@index([status])
}
